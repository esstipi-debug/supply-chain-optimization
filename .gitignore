~$*.xlsx
~$*.xlsm
*.tmp

# IDE
.vscode/
.idea/
*.pyc
__pycache__/

# Node (if adding web components)
node_modules/
.env
.env.local

# Python
*.egg-info/
dist/
build/
venv/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# graphify knowledge-graph output (generated)
graphify-out/

# generated client deliverables
deliverables/

# large external datasets (Kaggle / M5 etc. — fetched locally, not versioned)
data/kaggle/

# Misc — version the shared hook + settings, ignore personal/local overrides
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json
.secrets/
*.log
output/

# orchestrator job outputs
webapp/_jobs_output/
.gstack/
